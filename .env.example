# SecondCortex Configuration
# Copy this file to .env and fill in your values

# Gemini API Key (required for embeddings)
# Get yours at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Embedding backend: 'gemini' (default) or 'ollama' (if local model available)
EMBED_BACKEND=gemini

# Ollama settings (if using ollama backend)
OLLAMA_HOST=http://localhost:11434
OLLAMA_EMBED_MODEL=qwen3-embedding

# Extraction backend: 'ollama' (default) or 'gemini'
EXTRACTION_BACKEND=ollama
OLLAMA_MODEL=glm-5.1:cloud